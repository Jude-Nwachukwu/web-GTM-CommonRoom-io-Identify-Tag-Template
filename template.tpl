___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const callInWindow = require('callInWindow');
const logToConsole = require('logToConsole');

const email = data.email;
const name = data.name;
const debug = data.enableDebug;

const log = function() {
  if (debug) {
    logToConsole.apply(null, arguments);
  }
};

log('Common Room Identify Tag started');

if (!email) {
  log('ERROR: Email missing');
  data.gtmOnFailure();
  return;
}

const payload = {
  email: email
};

if (name) {
  payload.name = name;
}

log('Payload:', payload);

callInWindow('signals.identify', payload);

log('signals.identify executed');

data.gtmOnSuccess();


